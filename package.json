{
  "name": "@lifesystemsufpr/devops-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma central de CI/CD, governança e métricas para os repos da org lifesystemsufpr.",
  "type": "module",
  "scripts": {
    "bootstrap": "tsx scripts/bootstrap-repo.ts",
    "bootstrap:dry": "DRY_RUN=1 tsx scripts/bootstrap-repo.ts",
    "protect": "tsx scripts/sync-branch-protection.ts",
    "protect:dry": "DRY_RUN=1 tsx scripts/sync-branch-protection.ts",
    "lint": "eslint scripts demo/pipeline",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
