# PAT com escopo repo (e workflow se for alterar workflows nos repos alvo).
# Recomendado: fine-grained PAT com acesso só aos 7 repos da org lifesystemsufpr.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: nome do branch que o bootstrap cria nos repos alvo.
# BOOTSTRAP_BRANCH=chore/devops-hub-bootstrap

# Opcional: roda em modo dry-run (não escreve no GitHub).
# DRY_RUN=1
